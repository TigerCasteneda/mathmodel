# modeler-server deployment config — copy to deploy/.env and edit.
#   cp deploy/.env.example deploy/.env

# REQUIRED. JWT signing secret. The server defaults to an insecure dev value;
# you MUST override it in production. Generate one with:
#   openssl rand -hex 32
JWT_SECRET=

# Host port the server is published on (container always listens on 3001).
HOST_PORT=3001

# Log verbosity: error | warn | info | debug | trace
RUST_LOG=info

# --- Not needed by the server itself ---
# AI provider keys (DeepSeek / Firecrawl / Tavily / Context7) are configured
# per-user in the Tauri client, NOT here. The server stores no AI credentials.
